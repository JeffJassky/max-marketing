{
  "name": "MaxMarketing",
  "version": "1.0.0",
  "private": true,
  "main": "index.js",
  "license": "MIT",
  "workspaces": [
    "src/client"
  ],
  "scripts": {
    "dev:server": "nodemon --watch src/server --watch src/shared --exec \"ts-node --transpile-only --compiler-options '{\\\"module\\\":\\\"commonjs\\\",\\\"esModuleInterop\\\":true,\\\"moduleResolution\\\":\\\"node\\\"}' src/server/index.ts\"",
    "dev:client": "yarn workspace maxed-marketing-client dev",
    "test:e2e": "npx playwright test --config e2e/playwright.config.ts",
    "test:e2e:headed": "npx playwright test --config e2e/playwright.config.ts --headed",
    "test:e2e:debug": "npx playwright test --config e2e/playwright.config.ts --debug",
    "start": "node dist/server/index.js",
    "start:worker": "node --max-old-space-size=768 dist/queue/worker.js",
    "build": "yarn build:client && tsc",
    "build:server": "tsc",
    "start:server": "ts-node --transpile-only --compiler-options '{\"module\":\"commonjs\",\"esModuleInterop\":true,\"moduleResolution\":\"node\"}' src/server/index.ts",
    "build:client": "yarn workspace maxed-marketing-client build",
    "preview:client": "yarn workspace maxed-marketing-client preview",
    "tsc": "tsc",
    "cli": "npx tsx src/cli/index.ts",
    "worker": "npx tsx src/queue/worker.ts",
    "scheduler": "npx tsx src/queue/scheduler.ts",
    "enqueue": "npx tsx src/queue/enqueue.ts",
    "analyze-errors": "npx tsx src/cli/analyze-agent-errors.ts",
    "prepare": "husky",
    "shopify:tunnel": "shopify app dev"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1006.0",
    "@aws-sdk/lib-storage": "^3.1006.0",
    "@bull-board/api": "6.20.5",
    "@bull-board/express": "^6.20.5",
    "@google-cloud/bigquery": "^8.1.1",
    "@google/generative-ai": "^0.24.1",
    "@sendgrid/mail": "^8.1.6",
    "@shopify/shopify-api": "^13.0.0",
    "@types/glob": "^9.0.0",
    "@types/inquirer": "8.2.4",
    "@types/lodash": "^4.17.21",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.70.2",
    "chalk": "4.1.2",
    "chart.js": "^4.5.1",
    "connect-mongo": "^6.0.0",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "express-session": "^1.19.0",
    "glob": "^13.0.0",
    "google-auth-library": "^10.5.0",
    "inquirer": "8.2.4",
    "jsep": "^1.4.0",
    "knex": "^3.1.0",
    "lodash": "^4.17.21",
    "mongoose": "^9.2.3",
    "node-sql-parser": "^5.4.0",
    "passport": "^0.7.0",
    "passport-local": "^1.0.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "undici": "^7.22.0",
    "verror": "^1.10.1",
    "vite": "^7.2.6",
    "vue-chartjs": "^5.3.3",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/bcryptjs": "^3.0.0",
    "@types/express": "^5.0.6",
    "@types/express-session": "^1.18.2",
    "@types/node": "^24.10.1",
    "@types/passport": "^1.0.17",
    "@types/passport-local": "^1.0.38",
    "@types/verror": "^1.10.11",
    "husky": "^9.1.7",
    "mongodb-memory-server": "^11.0.1",
    "nodemon": "^3.1.11",
    "pino-pretty": "^13.1.3",
    "vitest": "^4.0.14"
  }
}
